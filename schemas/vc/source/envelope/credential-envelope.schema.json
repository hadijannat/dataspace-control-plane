{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataspace-control-plane.internal/schemas/vc/source/envelope/credential-envelope.schema.json",
  "title": "Verifiable Credential Envelope",
  "description": "Structural shape of a W3C Verifiable Credential (VC Data Model 2.0). Validates the outer envelope — context, type, issuer, validity window, credential subject, and optional proof. Does not validate proof cryptographic correctness or credential-profile-specific subject fields.",
  "x-source-standard": "W3C Verifiable Credentials Data Model 2.0",
  "x-source-version": "2.0",
  "x-pack-dependencies": [],

  "type": "object",
  "required": ["@context", "type", "issuer", "credentialSubject"],
  "additionalProperties": true,

  "properties": {
    "@context": {
      "description": "JSON-LD context. First value must be the W3C VC v2 context URI.",
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "format": "uri"},
          "prefixItems": [
            {"const": "https://www.w3.org/ns/credentials/v2"}
          ]
        },
        {
          "type": "string",
          "const": "https://www.w3.org/ns/credentials/v2"
        }
      ]
    },
    "id": {
      "type": "string",
      "format": "uri",
      "description": "Optional stable URI for this credential instance"
    },
    "type": {
      "description": "Type array. Must include 'VerifiableCredential'.",
      "type": "array",
      "minItems": 1,
      "contains": {"const": "VerifiableCredential"},
      "items": {"type": "string"}
    },
    "issuer": {
      "description": "Credential issuer — URI string or object with 'id' URI.",
      "oneOf": [
        {"type": "string", "format": "uri"},
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {"type": "string", "format": "uri"},
            "name": {"type": "string"}
          },
          "additionalProperties": true
        }
      ]
    },
    "validFrom": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 datetime when the credential becomes valid (VC 2.0)"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 datetime when the credential expires (VC 2.0, optional)"
    },
    "credentialSubject": {
      "description": "The subject of the credential. May be a single object or an array.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "id": {"type": "string", "format": "uri"}
          },
          "additionalProperties": true
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string", "format": "uri"}
            },
            "additionalProperties": true
          }
        }
      ]
    },
    "credentialSchema": {
      "description": "Optional reference to the credential schema.",
      "$ref": "https://dataspace-control-plane.internal/schemas/vc/source/envelope/credential-schema-ref.schema.json"
    },
    "credentialStatus": {
      "description": "Optional status mechanism reference.",
      "$ref": "https://dataspace-control-plane.internal/schemas/vc/source/integrity/status-ref.schema.json"
    },
    "proof": {
      "description": "Optional cryptographic proof over the credential.",
      "$ref": "https://dataspace-control-plane.internal/schemas/vc/source/integrity/proof-metadata.schema.json"
    }
  }
}
