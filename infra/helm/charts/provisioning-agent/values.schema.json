{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "provisioning-agent Helm values schema",
  "type": "object",
  "required": ["image", "service", "secrets", "config", "resources"],
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "image": {
      "type": "object",
      "required": ["repository"],
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_][A-Za-z0-9_.-]{0,127}$"
        },
        "digest": {
          "type": "string",
          "pattern": "^(sha256:[a-f0-9]{64}|sha256:REPLACE_WITH_REAL_DIGEST)$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "oneOf": [
        {
          "required": ["tag"],
          "not": {
            "required": ["digest"]
          }
        },
        {
          "required": ["digest"],
          "not": {
            "required": ["tag"]
          }
        }
      ]
    },
    "service": {
      "type": "object",
      "required": ["port", "targetPort"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "secrets": {
      "type": "object",
      "required": ["vaultSecretName", "keycloakAdminSecretName", "edcApiKeySecretName"],
      "additionalProperties": false,
      "properties": {
        "vaultSecretName": {
          "type": "string",
          "minLength": 1
        },
        "keycloakAdminSecretName": {
          "type": "string",
          "minLength": 1
        },
        "edcApiKeySecretName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "config": {
      "type": "object",
      "required": ["logLevel", "otlpEndpoint", "edcControlUrl", "edcManagementUrl", "keycloakAdminUrl"],
      "additionalProperties": false,
      "properties": {
        "logLevel": {
          "type": "string",
          "enum": ["DEBUG", "INFO", "WARNING", "ERROR"]
        },
        "otlpEndpoint": {
          "type": "string",
          "minLength": 1
        },
        "edcControlUrl": {
          "type": "string",
          "minLength": 1
        },
        "edcManagementUrl": {
          "type": "string",
          "minLength": 1
        },
        "keycloakAdminUrl": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    }
  }
}
