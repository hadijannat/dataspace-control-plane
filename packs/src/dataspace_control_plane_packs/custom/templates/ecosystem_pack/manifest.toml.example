# Pin each normative source you consume.
# Do NOT fetch normative sources at runtime — pin them under vocab/pinned/.
# [[normative_sources]]
# source_uri = "https://example.org/your-spec"
# version = "1.0"
# retrieval_date = "2026-01-01"
# sha256 = "..."
# local_filename = "vocab/pinned/your_spec_v1.0.pdf"
# effective_from = "2026-01-01"
