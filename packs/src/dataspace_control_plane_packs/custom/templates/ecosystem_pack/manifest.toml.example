# Ecosystem Pack Manifest Template
# Rename to manifest.toml and fill in your values.
pack_id = "your_ecosystem_id"
pack_kind = "ecosystem"   # or "regulation" or "custom"
version = "1.0.0"
display_name = "Your Ecosystem Display Name"
description = "One-paragraph description of what this ecosystem pack provides."
activation_scope = "tenant"   # or "legal_entity" or "environment"
default_priority = 100
conflicts = []   # list pack_ids that this pack is incompatible with

[compatibility]
core = ">=0.1.0"

# Declare each capability interface you implement.
# Remove entries for capabilities you do not implement.
[[capabilities]]
capability = "RequirementProvider"
interface_class = "dataspace_control_plane_packs.your_ecosystem_id.api.YourRequirementProvider"

# [[capabilities]]
