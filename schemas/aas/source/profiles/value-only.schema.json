{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataspace-control-plane.internal/schemas/aas/source/profiles/value-only.schema.json",
  "title": "AAS Value-Only Payload",
  "description": "AAS value-only serialization format per IDTA Release 25-01 Part 2. Used by the Submodel API's value-only endpoints (/value). Strips metamodel metadata, returning only idShort → value pairs.",
  "x-source-standard": "IDTA AAS Release 25-01 Part 2",
  "x-source-version": "25-01",
  "x-pack-dependencies": [],

  "type": "object",
  "description": "Map of idShort → value for each submodel element. Nested SubmodelElementCollections are represented as nested objects.",
  "additionalProperties": {
    "oneOf": [
      {"type": "string"},
      {"type": "number"},
      {"type": "boolean"},
      {"type": "null"},
      {
        "type": "object",
        "description": "Nested SubmodelElementCollection or complex value",
        "additionalProperties": true
      },
      {
        "type": "array",
        "description": "SubmodelElementList value"
      }
    ]
  },
  "examples": [
    {
      "BatteryId":              "BAT-2026-001",
      "ManufacturerName":       "Example GmbH",
      "CarbonFootprintKgCO2eq": "42.5",
      "ChemistryInfo": {
        "BatteryChemistry": "NMC",
        "CapacityRatedKwh": "75.0"
      }
    }
  ]
}
