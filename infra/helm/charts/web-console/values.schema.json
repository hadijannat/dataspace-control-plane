{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "web-console Helm values schema",
  "type": "object",
  "required": ["image", "service", "config", "resources"],
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(sha256:[a-f0-9]{64}|[0-9]+\\.[0-9]+\\.[0-9]+.*)$",
          "description": "Image tag — semver or sha256 digest"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["port"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "apiBaseUrl": {
          "type": "string",
          "minLength": 1,
          "description": "Internal URL of the control-api service"
        },
        "keycloakUrl": {
          "type": "string",
          "description": "External Keycloak URL for browser-side OIDC flow"
        },
        "keycloakRealm": {
          "type": "string",
          "description": "Keycloak realm name"
        },
        "keycloakClientId": {
          "type": "string"
        },
        "nextTelemetryDisabled": {
          "type": "string"
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "hosts": {
          "type": "array",
          "description": "At least one host must be specified when ingress is enabled"
        },
        "tls": {
          "type": "array"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    }
  }
}
