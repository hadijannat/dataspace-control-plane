{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataspace-control-plane.internal/schemas/vc/source/integrity/status-ref.schema.json",
  "title": "Credential Status Reference",
  "description": "Reference to a credential status mechanism within a Verifiable Credential. Validates the outer status entry shape only — mechanism-specific fields are additionalProperties.",
  "x-source-standard": "W3C Verifiable Credentials Data Model 2.0",
  "x-source-version": "2.0",
  "x-pack-dependencies": [],

  "oneOf": [
    {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "format": "uri",
          "description": "URI identifying this status entry"
        },
        "type": {
          "type": "string",
          "description": "Status mechanism type, e.g. BitstringStatusListEntry, StatusList2021Entry",
          "examples": ["BitstringStatusListEntry", "StatusList2021Entry"]
        }
      }
    },
    {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "additionalProperties": true,
        "properties": {
          "id":   {"type": "string", "format": "uri"},
          "type": {"type": "string"}
        }
      }
    }
  ]
}
