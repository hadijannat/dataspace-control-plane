{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "provisioning-agent Helm values schema",
  "type": "object",
  "required": ["image", "service", "secrets", "config", "resources"],
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(sha256:[a-f0-9]{64}|[0-9]+\\.[0-9]+\\.[0-9]+.*)$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["port"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "secrets": {
      "type": "object",
      "required": ["vaultSecretName", "keycloakAdminSecretName", "edcApiKeySecretName"],
      "additionalProperties": true,
      "properties": {
        "vaultSecretName": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the K8s Secret referencing Vault credentials"
        },
        "keycloakAdminSecretName": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the K8s Secret containing Keycloak admin credentials"
        },
        "edcApiKeySecretName": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the K8s Secret containing EDC management API key"
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "logLevel": {
          "type": "string",
          "enum": ["DEBUG", "INFO", "WARNING", "ERROR"]
        },
        "otlpEndpoint": {
          "type": "string"
        },
        "edcControlUrl": {
          "type": "string",
          "description": "EDC connector control plane URL"
        },
        "edcManagementUrl": {
          "type": "string",
          "description": "EDC connector management API URL"
        },
        "keycloakAdminUrl": {
          "type": "string",
          "description": "Keycloak admin REST API URL"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    }
  }
}
