{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataspace-control-plane.internal/schemas/aas/source/profiles/shell-descriptor.schema.json",
  "title": "AAS Shell Descriptor",
  "description": "AAS Shell Descriptor shape per IDTA Release 25-01 Part 2 APIs. Used by the AAS Registry to describe where a shell can be reached (endpoints) and which submodels it exposes.",
  "x-source-standard": "IDTA AAS Release 25-01 Part 2",
  "x-source-version": "25-01",
  "x-pack-dependencies": [],

  "$defs": {
    "endpoint": {
      "$ref": "https://dataspace-control-plane.internal/schemas/aas/source/profiles/endpoint-ref.schema.json"
    },
    "submodelDescriptor": {
      "$ref": "https://dataspace-control-plane.internal/schemas/aas/source/profiles/submodel-descriptor.schema.json"
    }
  },

  "type": "object",
  "required": ["id"],
  "additionalProperties": true,

  "properties": {
    "id": {
      "type": "string",
      "description": "Shell identifier — matches AssetAdministrationShell.id"
    },
    "idShort": {
      "type": "string"
    },
    "globalAssetId": {
      "type": "string",
      "description": "Asset identifier — matches AssetInformation.globalAssetId"
    },
    "assetKind": {
      "type": "string",
      "enum": ["Instance", "NotApplicable", "Type"]
    },
    "assetType": {"type": "string"},
    "specificAssetIds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name":  {"type": "string"},
          "value": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "description": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["language", "text"],
        "properties": {
          "language": {"type": "string"},
          "text":     {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "displayName": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["language", "text"],
        "properties": {
          "language": {"type": "string"},
          "text":     {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "endpoints": {
      "type": "array",
      "items": {"$ref": "#/$defs/endpoint"},
      "description": "Protocol-specific endpoint addresses for this shell"
    },
    "submodelDescriptors": {
      "type": "array",
      "items": {"$ref": "#/$defs/submodelDescriptor"}
    }
  }
}
