{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dataspace-control-plane.internal/schemas/aas/source/profiles/shell.schema.json",
  "title": "AAS Shell Instance",
  "description": "Implementation profile for an AAS Asset Administration Shell (shell instance) per IDTA Release 25-01. Validates the shell envelope: id, idShort, assetInformation, and submodel references.",
  "x-source-standard": "IDTA AAS Release 25-01 Part 1",
  "x-source-version": "25-01",
  "x-pack-dependencies": [],

  "$defs": {
    "reference": {
      "$ref": "https://dataspace-control-plane.internal/schemas/aas/source/profiles/submodel.schema.json#/$defs/reference"
    },
    "langStringSet": {
      "$ref": "https://dataspace-control-plane.internal/schemas/aas/source/profiles/submodel.schema.json#/$defs/langStringSet"
    },
    "submodelRef": {
      "type": "object",
      "required": ["type", "keys"],
      "additionalProperties": false,
      "description": "ModelReference to a Submodel",
      "properties": {
        "type": {"type": "string", "const": "ModelReference"},
        "keys": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "required": ["type", "value"],
            "additionalProperties": false,
            "properties": {
              "type":  {"type": "string", "const": "Submodel"},
              "value": {"type": "string"}
            }
          }
        }
      }
    }
  },

  "type": "object",
  "required": ["id", "modelType", "assetInformation"],
  "additionalProperties": true,

  "properties": {
    "modelType": {
      "type": "string",
      "const": "AssetAdministrationShell"
    },
    "id": {
      "type": "string",
      "description": "Globally unique AAS identifier (IRI or opaque URN)"
    },
    "idShort": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_]{0,127}$"
    },
    "description": {"$ref": "#/$defs/langStringSet"},
    "displayName":  {"$ref": "#/$defs/langStringSet"},
    "administration": {
      "type": "object",
      "properties": {
        "version":  {"type": "string"},
        "revision": {"type": "string"}
      },
      "additionalProperties": false
    },
    "assetInformation": {
      "type": "object",
      "required": ["assetKind", "globalAssetId"],
      "additionalProperties": false,
      "properties": {
        "assetKind": {
          "type": "string",
          "enum": ["Instance", "NotApplicable", "Type"]
        },
        "globalAssetId": {
          "type": "string",
          "description": "IRI or opaque identifier of the physical/digital asset"
        },
        "specificAssetIds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "additionalProperties": false,
            "properties": {
              "name":             {"type": "string"},
              "value":            {"type": "string"},
              "externalSubjectId": {"$ref": "#/$defs/reference"},
              "semanticId":       {"$ref": "#/$defs/reference"}
            }
          }
        },
        "assetType": {"type": "string"},
        "defaultThumbnail": {
          "type": "object",
          "properties": {
            "path":        {"type": "string"},
            "contentType": {"type": "string"}
          },
          "additionalProperties": false
        }
      }
    },
    "submodels": {
      "type": "array",
      "items": {"$ref": "#/$defs/submodelRef"},
      "description": "References to Submodels associated with this shell"
    },
    "derivedFrom": {
      "$ref": "#/$defs/reference",
      "description": "Reference to the AAS Template this instance was derived from"
    }
  }
}
